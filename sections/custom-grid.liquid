{% liquid
  assign collection = section.settings.collection
  assign max_items = section.settings.product_count
  assign columns = section.settings.columns
%}

<section class="featured-collection section-{{ section.id }}">

  {% if section.settings.title != blank %}
    <div class="section-header">
      <h2>{{ section.settings.title }}</h2>

      {% if section.settings.show_view_all and collection != blank %}
        <a href="{{ collection.url }}" class="view-all">View all</a>
      {% endif %}
    </div>
  {% endif %}

  <div class="product-grid">

    {% for product in collection.products limit: max_items %}

        <div class="product-card">

          <a href="{{ product.url }}" class="image-wrapper">
            <img src="{{ product.featured_image | image_url: width: 800 }}">
          </a>
        
          <!-- + BUTTON -->
          <button class="qv-btn" data-id="{{ product.id }}">+</button>
        
          <!-- PRODUCT JSON -->
          <script type="application/json" id="product-data-{{ product.id }}">
            {{ product | json }}
          </script>
        
        </div>

    {% endfor %}

  </div>

</section>

<div id="qv-modal" class="qv-modal">
  <div class="qv-box">

    <span class="qv-close">×</span>

    <div class="qv-grid">

      <div class="qv-left">
        <img id="qv-img">
        <div class="content-box">
            <h5 id="qv-title"></h5>
            <p id="qv-price"></p>
            <p id="qv-desc"></p>
        </div>
      </div>

      <div class="qv-right">

        <div class="qv-option">
          <label>Color</label>
          <select id="qv-size"></select>
        </div>
        <div class="qv-option">
          <label>Size</label>
          <div id="qv-colors"></div>
        </div>

        <button id="qv-add">ADD TO CART</button>
        {%  if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Product count"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 16,
      "label": "Gap"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}

<style>
    .featured-collection {
      padding: 40px;
    }
    
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
    
    .section-header h2 {
        font-size: 36px;
        font-weight: 400;
        line-height: 120%;
        font-family: 'Lustria';
        padding-bottom: 10px;
    }
    
    .view-all {
      font-size: 14px;
      text-decoration: underline;
    }
    
    .featured-collection {
      width: 100%;
      max-width: 100%;
    }
    
    .product-grid {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }
    
    /* Shopify style responsive */
    @media(max-width: 990px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media(max-width: 600px) {
      .product-grid {
        grid-template-columns: repeat(1, 1fr);
      }
    }
    
    .product-card {
      text-align: left;
    }
    
    .image-wrapper {
      display: block;
      aspect-ratio: 1/1.2;
      overflow: hidden;
    }
    
    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: 0.4s;
    }
    
    .product-card:hover img {
      transform: scale(1.05);
    }
    
    .product-info h3 {
      font-size: 14px;
      margin-top: 10px;
    }
    
    .product-info p {
      font-size: 13px;
      opacity: 0.7;
    }
    
    .product-info {
       display: none;
    }
    
    .qv-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      justify-content: center;
      align-items: center;
      z-index: 9999;
    }
    
    .qv-box {
      background: #fff;
      width: 320px;
      padding: 0 20px 20px;
      position: relative;
    }
    
    .qv-close {
      position: absolute;
      top: 0;
      right: 15px;
      font-size: 22px;
      cursor: pointer;
    }
    
    .qv-left {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
    
    {% comment %} .qv-left img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    } {% endcomment %}
    
    .qv-right h2 {
      font-size: 18px;
      margin-bottom: 10px;
    }
    
    .qv-option {
      margin-top: 15px;
    }
    
    #qv-colors button {
      border: 1px solid #000;
      background: #fff;
      padding: 6px 12px;
      margin-right: 6px;
      cursor: pointer;
    }
    
    #qv-add {
      margin-top: 20px;
      width: 100%;
      background: black;
      color: white;
      padding: 12px;
      border: none;
      cursor: pointer;
    }
    
    .qv-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 1px solid #fff;
      background: #fff;
      cursor: pointer;
      opacity: 0;
      transition: 0.3s;
    }
    
    .product-card {
      position: relative;
    }
    
    .product-card:hover .qv-btn {
      opacity: 1;
    }
    .qv-left {
      display: flex;
        align-items: flex-end;
      gap: 12px;
      padding-top: 30px;
    }

    /* PRODUCT IMAGE */
    .qv-left img {
      width: 120px;
      height: 140px;
      object-fit: cover;
    }
    
    /* TITLE */
    #qv-title {
        font-size: 16px;
        font-weight: 300;
        margin-bottom: 10px;
        color: #111;
        line-height: 120%;
    }
    
    /* PRICE */
    #qv-price {
      font-size: 16px;
      font-weight: 400;
      color: #444;
      margin: 0;
    }
    
    /* DESCRIPTION */
    #qv-desc {
        font-size: 14px;
        font-weight: 300;
        line-height: 110%;
        color: #000;
        margin-top: 10px;
        letter-spacing: -1%;
    }
    
    /* MOBILE RESPONSIVE */
    @media (max-width: 768px) {
      #qv-title {
        font-size: 16px;
      }
    
      #qv-price {
        font-size: 14px;
      }
    
      #qv-desc {
        font-size: 12px;
      }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    
      const modal = document.getElementById("qv-modal");
    
      document.querySelectorAll(".qv-btn").forEach(btn => {
    
        btn.addEventListener("click", () => {
    
          const product = JSON.parse(
            document.getElementById(`product-data-${btn.dataset.id}`).textContent
          );
    
          // OPEN MODAL
          modal.style.display = "flex";
    
          // BASIC DATA
          document.getElementById("qv-title").innerText = product.title;
          document.getElementById("qv-price").innerText = (product.price / 100).toFixed(2);
          document.getElementById("qv-img").src = product.images?.[0] || "";
          document.getElementById("qv-desc").innerHTML = product.description.substring(0, 50) + "...";
    
          // VARIANTS
          let colors = new Set();
          let sizes = new Set();
    
          product.variants.forEach(v => {
            let parts = v.title.split(" / ");
            if (parts[0]) colors.add(parts[0]);
            if (parts[1]) sizes.add(parts[1]);
          });
    
          const colorBox = document.getElementById("qv-colors");
          const sizeBox = document.getElementById("qv-size");
    
          colorBox.innerHTML = "";
          sizeBox.innerHTML = "";
    
          let selectedColor = product.variants[0]?.option1;
          let selectedSize = product.variants[0]?.option2;
    
          colors.forEach(c => {
            let b = document.createElement("button");
            b.innerText = c;
            b.onclick = () => selectedColor = c;
            colorBox.appendChild(b);
          });
    
          sizes.forEach(s => {
            let opt = document.createElement("option");
            opt.text = s;
            sizeBox.add(opt);
          });
    
          sizeBox.onchange = e => selectedSize = e.target.value;
    
          // ADD TO CART
          document.getElementById("qv-add").onclick = () => {
    
            const variant = product.variants.find(v => {
              return (!selectedColor || v.option1 === selectedColor) &&
                     (!selectedSize || v.option2 === selectedSize);
            });
    
            if (!variant) return;
    
            fetch("/cart/add.js", {
              method: "POST",
              headers: {"Content-Type": "application/json"},
              body: JSON.stringify({
                id: variant.id,
                quantity: 1
              })
            });
    
          };
    
        });
    
      });
    
      // CLOSE MODAL
      document.querySelector(".qv-close").onclick = () => {
        modal.style.display = "none";
      };
    
    });

</script>

