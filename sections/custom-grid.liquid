{% assign max_items = section.settings.max_products %}

<section class="figma-product-list">

  <div class="grid">

    {% for product in section.settings.collection.products limit: max_items %}

      <div class="card">

        <!-- REAL PRODUCT CARD (simple safe version) -->
        <img src="{{ product.featured_image | image_url }}" />
        <h3>{{ product.title }}</h3>
        <p>{{ product.price | money }}</p>

        <!-- QUICK VIEW -->
        <button class="quick-view-btn" data-id="{{ product.id }}">
          +
        </button>

        <!-- REAL DATA -->
        <script type="application/json" id="product-data-{{ product.id }}">
          {{ product | json }}
        </script>

      </div>

    {% endfor %}

  </div>

</section>

<!-- MODAL -->
<div id="qv-modal" class="qv-modal">
  <div class="qv-box">

    <span class="qv-close">&times;</span>

    <div class="qv-content">

      <div class="qv-left">
        <img id="qv-img">
      </div>

      <div class="qv-right">

        <h2 id="qv-title"></h2>
        <p id="qv-price"></p>
        <div id="qv-desc"></div>

        <div class="qv-option">
          <label>Color</label>
          <div id="qv-colors"></div>
        </div>

        <div class="qv-option">
          <label>Size</label>
          <select id="qv-size"></select>
        </div>

        <button id="qv-add">ADD TO CART →</button>

      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}

<style>
.grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 20px;
}

.card {
  position: relative;
}

.card img {
  width: 100%;
  display: block;
}

.quick-view-btn {
  position: absolute;
  bottom: 10px;
  right: 10px;
  width: 35px;
  height: 35px;
  border-radius: 50%;
  background: #fff;
  border: 1px solid #000;
  cursor: pointer;
}

/* MODAL */
.qv-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.qv-box {
  background: #fff;
  width: 750px;
  padding: 25px;
}

.qv-content {
  display: flex;
  gap: 20px;
}

.qv-left img {
  width: 280px;
}

.qv-right {
  flex: 1;
}

.qv-option {
  margin-top: 15px;
}

#qv-colors button {
  margin-right: 8px;
  border: 1px solid #000;
  padding: 5px 10px;
  background: white;
  cursor: pointer;
}

#qv-add {
  margin-top: 20px;
  width: 100%;
  background: black;
  color: white;
  padding: 12px;
  border: none;
  cursor: pointer;
}

.qv-close {
  float: right;
  cursor: pointer;
}
</style>

<script>
document.querySelectorAll(".quick-view-btn").forEach(btn => {

  btn.addEventListener("click", () => {

    const id = btn.dataset.id;

    const product = JSON.parse(
      document.getElementById(`product-data-${id}`).textContent
    );

    // BASIC DATA
    document.getElementById("qv-title").innerText = product.title;
    document.getElementById("qv-price").innerText =
      (product.price / 100).toFixed(2);

    document.getElementById("qv-img").src =
      product.images?.[0] || "";

    document.getElementById("qv-desc").innerHTML =
      product.description || "";

    // VARIANTS
    let colors = new Set();
    let sizes = new Set();

    product.variants.forEach(v => {
      let parts = v.title.split(" / ");
      if (parts[0]) colors.add(parts[0]);
      if (parts[1]) sizes.add(parts[1]);
    });

    const colorBox = document.getElementById("qv-colors");
    const sizeBox = document.getElementById("qv-size");

    colorBox.innerHTML = "";
    sizeBox.innerHTML = "";

    let selectedColor = "";
    let selectedSize = "";

    colors.forEach(c => {
      const b = document.createElement("button");
      b.innerText = c;
      b.onclick = () => selectedColor = c;
      colorBox.appendChild(b);
    });

    sizes.forEach(s => {
      const opt = document.createElement("option");
      opt.text = s;
      sizeBox.add(opt);
    });

    selectedColor = product.variants[0]?.option1;
    selectedSize = product.variants[0]?.option2;

    sizeBox.onchange = e => selectedSize = e.target.value;

    // ADD TO CART
    document.getElementById("qv-add").onclick = () => {

      const variant = product.variants.find(v =>
        v.option1 === selectedColor &&
        v.option2 === selectedSize
      );

      if (!variant) return;

      fetch("/cart/add.js", {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

    };

    document.getElementById("qv-modal").style.display = "flex";
  });

});

// CLOSE
document.querySelector(".qv-close").onclick = () => {
  document.getElementById("qv-modal").style.display = "none";
};

</script>