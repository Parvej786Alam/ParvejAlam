<section class="product-grid">
  <div class="grid">

    {% for block in section.blocks %}
      {% assign product = all_products[block.settings.product] %}

      {% if product != blank %}
        <div class="product-card" data-handle="{{ product.handle }}">

          <div class="img-box">
            <img src="{{ product.featured_image | image_url: width: 700 }}">
            <button class="quick-view">+</button>
          </div>

          <div class="info">
            <h3>{{ product.title }}</h3>
            <p>{{ product.price | money }}</p>
          </div>

        </div>
      {% endif %}

    {% endfor %}

  </div>
</section>


<!-- DRAWER -->
<div class="drawer-overlay" id="overlay"></div>

<div class="product-drawer" id="drawer">

  <button class="close-drawer" id="closeDrawer">×</button>

  <div class="drawer-content">

    <div class="gallery">
      <img id="mainImg" />

      <div class="thumbs" id="thumbs"></div>
    </div>

    <div class="details">
      <h2 id="d-title"></h2>
      <p id="d-price"></p>

      <div class="swatches" id="swatches"></div>

      <button id="addCart">Add to Cart</button>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Grid",
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ],
  "max_blocks": 6
}
{% endschema %}

<style>
/* GRID */
.product-grid .grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:10px;
}

.product-card{
  border:1px solid #eee;
  overflow:hidden;
  background:#fff;
height: fit-content;
}

.img-box{
  position:relative;
}

.img-box img{
  width:100%;
  display:block;
}

/* + BUTTON */
.quick-view{
  position:absolute;
  top:10px;
  right:10px;
  width:36px;
  height:36px;
  border-radius:50%;
  border:none;
  background:#000;
  color:#fff;
  cursor:pointer;
  opacity:0;
  transition:.3s;
}

.product-card:hover .quick-view{
  opacity:1;
}

/* OVERLAY */
.drawer-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.4);
  opacity:0;
  visibility:hidden;
  transition:.3s;
}

/* DRAWER */
.product-drawer{
  position:fixed;
  top:0;
  right:-500px;
  width:450px;
  height:100%;
  background:#fff;
  z-index:999;
  transition:.5s;
  padding:20px;
  overflow-y:auto;
}

.product-drawer.active{
  right:0;
}

.drawer-overlay.active{
  opacity:1;
  visibility:visible;
}

/* GALLERY */
.gallery img{
  width:100%;
  border-radius:10px;
}

.thumbs{
  display:flex;
  gap:10px;
  margin-top:10px;
}

.thumbs img{
  width:60px;
  cursor:pointer;
  border:1px solid #eee;
}

/* SWATCHES */
.swatch{
  width:25px;
  height:25px;
  border-radius:50%;
  border:1px solid #ddd;
  display:inline-block;
  margin:5px;
  cursor:pointer;
}

.swatch.active{
  border:2px solid #000;
}

/* BUTTON */
#addCart{
  width:100%;
  padding:12px;
  background:#000;
  color:#fff;
  border:none;
  margin-top:15px;
  cursor:pointer;
}

/* MOBILE */
@media(max-width:768px){
  .product-drawer{
    width:100%;
  }
}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<script>
let selectedVariant = null;
let productData = null;

/* OPEN DRAWER */
document.querySelectorAll(".quick-view").forEach(btn => {
  btn.addEventListener("click", async (e) => {

    e.stopPropagation();

    const handle = btn.closest(".product-card").dataset.handle;

    const res = await fetch(`/products/${handle}.js`);
    productData = await res.json();

    document.getElementById("d-title").innerText = productData.title;
    document.getElementById("d-price").innerText = (productData.price/100).toFixed(2);

    selectedVariant = productData.variants[0]?.id;

    /* IMAGE GALLERY */
    document.getElementById("mainImg").src = productData.images[0];

    let thumbs = "";
    productData.images.forEach(img=>{
      thumbs += `<img src="${img}" onclick="document.getElementById('mainImg').src='${img}'">`;
    });

    document.getElementById("thumbs").innerHTML = thumbs;

    /* SWATCHES */
    let swatchHTML = "";

    productData.variants.forEach(v=>{
      let color = v.title.toLowerCase();

      swatchHTML += `<span class="swatch" data-id="${v.id}" title="${v.title}"></span>`;
    });

    document.getElementById("swatches").innerHTML = swatchHTML;

    openDrawer();
  });
});

/* OPEN DRAWER ANIMATION */
function openDrawer(){
  document.getElementById("drawer").classList.add("active");
  document.getElementById("overlay").classList.add("active");

  gsap.fromTo("#drawer",{x:500},{x:0,duration:0.4});
}

/* CLOSE */
document.getElementById("closeDrawer").onclick = closeDrawer;
document.getElementById("overlay").onclick = closeDrawer;

function closeDrawer(){
  document.getElementById("drawer").classList.remove("active");
  document.getElementById("overlay").classList.remove("active");
}

/* SWATCH SELECT */
document.addEventListener("click",(e)=>{
  if(e.target.classList.contains("swatch")){
    document.querySelectorAll(".swatch").forEach(s=>s.classList.remove("active"));
    e.target.classList.add("active");
    selectedVariant = e.target.dataset.id;
  }
});

/* ADD TO CART */
document.getElementById("addCart").addEventListener("click", async ()=>{

  await fetch('/cart/add.js',{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      id:selectedVariant,
      quantity:1
    })
  });

  alert("Added to cart!");
});
</script>