<section class="product-grid">
  <div class="grid">
    {% for block in section.blocks %}
      {% assign product = all_products[block.settings.product] %}

      {% if product != blank %}
        <div class="product-card" data-product-handle="{{ product.handle }}">
          <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}">
          <h3>{{ product.title }}</h3>
          <p>{{ product.price | money }}</p>
        </div>
      {% endif %}

    {% endfor %}
  </div>
</section>

<!-- POPUP -->
<div id="product-popup" style="display:none;">
  <div class="popup-inner">
    <h2 id="popup-title"></h2>
    <p id="popup-price"></p>

    <div id="popup-variants"></div>

    <button id="add-to-cart">Add to Cart</button>
    <button onclick="document.getElementById('product-popup').style.display='none'">
      Close
    </button>
  </div>
</div>

{% schema %}
{
  "name": "Custom Grid",
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ],
  "max_blocks": 6
}
{% endschema %}

<script>
let selectedVariantId = null;

// OPEN POPUP + LOAD PRODUCT
document.querySelectorAll(".product-card").forEach(card => {
  card.addEventListener("click", async () => {
    const handle = card.dataset.productHandle;

    const res = await fetch(`/products/${handle}.js`);
    const product = await res.json();

    document.getElementById("popup-title").innerText = product.title;
    document.getElementById("popup-price").innerText =
      (product.price / 100).toFixed(2);

    // VARIANTS
    let variantHTML = "";

    product.variants.forEach(v => {
      variantHTML += `
        <button class="variant-btn" data-id="${v.id}">
          ${v.title}
        </button>
      `;
    });

    document.getElementById("popup-variants").innerHTML = variantHTML;

    selectedVariantId = product.variants[0]?.id || null;

    document.getElementById("product-popup").style.display = "block";
  });
});


// SELECT VARIANT (EVENT DELEGATION)
document.addEventListener("click", (e) => {
  if (e.target.classList.contains("variant-btn")) {
    document.querySelectorAll(".variant-btn").forEach(btn => {
      btn.classList.remove("active");
    });

    e.target.classList.add("active");
    selectedVariantId = e.target.dataset.id;
  }
});


// ADD TO CART
document.getElementById("add-to-cart").addEventListener("click", async () => {
  if (!selectedVariantId) {
    alert("Please select a variant");
    return;
  }

  await fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      id: selectedVariantId,
      quantity: 1
    })
  });

  alert("Added to cart!");
});
</script>