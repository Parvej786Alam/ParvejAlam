{% assign max_items = section.settings.max_products %}

<section class="grid">

  {% for product in section.settings.collection.products limit: max_items %}

    <div class="card">

      <div class="img-wrap">
        <img src="{{ product.featured_image | image_url }}" />
      </div>

      <div class="meta">
        <h3>{{ product.title }}</h3>
        <p>{{ product.price | money }}</p>
      </div>

      <button class="quick-view-btn" data-id="{{ product.id }}">
        +
      </button>

      <script type="application/json" id="product-data-{{ product.id }}">
        {{ product | json }}
      </script>

    </div>

  {% endfor %}

</section>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}

<style>
.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
}

.card {
  position: relative;
  background: transparent;
}

/* IMAGE FIRST CLEAN LAYOUT */
.img-wrap {
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.4s ease;
}

/* TEXT MINIMAL LIKE FIGMA */
.meta {
  margin-top: 12px;
}

.meta h3 {
  font-size: 14px;
  font-weight: 400;
  margin: 0;
}

.meta p {
  font-size: 13px;
  opacity: 0.7;
  margin-top: 4px;
}

/* CLEAN FLOAT BUTTON */
.quick-view-btn {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: white;
  border: 1px solid rgba(0,0,0,0.2);
  opacity: 0;
  transition: 0.3s;
}

.card:hover .quick-view-btn {
  opacity: 1;
}

/* MODAL = FIGMA STYLE */
.qv-box {
  background: white;
  width: 900px;
  padding: 40px;
  border-radius: 12px;
}

.qv-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
}

.qv-left img {
  width: 100%;
  aspect-ratio: 1/1;
  object-fit: cover;
}

.qv-right h5 {
  font-size: 18px;
  font-weight: 400;
}

#qv-price {
  font-size: 16px;
  opacity: 0.7;
}
</style>

<script>
document.querySelectorAll(".quick-view-btn").forEach(btn => {

  btn.addEventListener("click", () => {

    const id = btn.dataset.id;

    const product = JSON.parse(
      document.getElementById(`product-data-${id}`).textContent
    );

    // BASIC DATA
    document.getElementById("qv-title").innerText = product.title;
    document.getElementById("qv-price").innerText =
      (product.price / 100).toFixed(2);

    document.getElementById("qv-img").src =
      product.images?.[0] || "";

    document.getElementById("qv-desc").innerHTML =
      product.description || "";

    // VARIANTS
    let colors = new Set();
    let sizes = new Set();

    product.variants.forEach(v => {
      let parts = v.title.split(" / ");
      if (parts[0]) colors.add(parts[0]);
      if (parts[1]) sizes.add(parts[1]);
    });

    const colorBox = document.getElementById("qv-colors");
    const sizeBox = document.getElementById("qv-size");

    colorBox.innerHTML = "";
    sizeBox.innerHTML = "";

    let selectedColor = "";
    let selectedSize = "";

    colors.forEach(c => {
      const b = document.createElement("button");
      b.innerText = c;
      b.onclick = () => selectedColor = c;
      colorBox.appendChild(b);
    });

    sizes.forEach(s => {
      const opt = document.createElement("option");
      opt.text = s;
      sizeBox.add(opt);
    });

    selectedColor = product.variants[0]?.option1;
    selectedSize = product.variants[0]?.option2;

    sizeBox.onchange = e => selectedSize = e.target.value;

    // ADD TO CART
    document.getElementById("qv-add").onclick = () => {

      const variant = product.variants.find(v =>
        v.option1 === selectedColor &&
        v.option2 === selectedSize
      );

      if (!variant) return;

      fetch("/cart/add.js", {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({
          id: variant.id,
          quantity: 1
        })
      });

    };

    document.getElementById("qv-modal").style.display = "flex";
  });

});

// CLOSE
document.querySelector(".qv-close").onclick = () => {
  document.getElementById("qv-modal").style.display = "none";
};

</script>