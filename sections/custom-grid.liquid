{% liquid
  assign collection = section.settings.collection
  assign max_items = section.settings.product_count
  assign columns = section.settings.columns
%}

<section class="featured-collection section-{{ section.id }}">

  {% if section.settings.title != blank %}
    <div class="section-header">
      <h2>{{ section.settings.title }}</h2>

      {% if section.settings.show_view_all and collection != blank %}
        <a href="{{ collection.url }}" class="view-all">View all</a>
      {% endif %}
    </div>
  {% endif %}

  <div class="product-grid">

    {% for product in collection.products limit: max_items %}

      <div class="product-card">

        <a href="{{ product.url }}" class="image-wrapper">
          <img src="{{ product.featured_image | image_url: width: 800 }}">
        </a>

        <div class="product-info">
          <h3>{{ product.title }}</h3>
          <p>{{ product.price | money }}</p>
        </div>

      </div>

    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Product count"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 16,
      "label": "Gap"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}

<style>
.featured-collection {
  padding: 40px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.section-header h2 {
  font-size: 22px;
  font-weight: 500;
}

.view-all {
  font-size: 14px;
  text-decoration: underline;
}

.featured-collection {
  width: 100%;
  max-width: 100%;
}

.product-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

/* Shopify style responsive */
@media(max-width: 990px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media(max-width: 600px) {
  .product-grid {
    grid-template-columns: repeat(1, 1fr);
  }
}

.product-card {
  text-align: left;
}

.image-wrapper {
  display: block;
  aspect-ratio: 1/1.2;
  overflow: hidden;
}

.image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.4s;
}

.product-card:hover img {
  transform: scale(1.05);
}

.product-info h3 {
  font-size: 14px;
  margin-top: 10px;
}

.product-info p {
  font-size: 13px;
  opacity: 0.7;
}

.product-info {
   display: none;
}
</style>

