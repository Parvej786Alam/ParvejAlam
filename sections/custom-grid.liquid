<section class="future-shop">

  <aside class="future-filter">
    <input type="text" id="search" placeholder="Search universe...">
    <input type="range" id="price" min="0" max="10000">
  </aside>

  <div class="future-grid">

    {% for block in section.blocks %}
      {% assign product = all_products[block.settings.product] %}

      {% if product != blank %}

      <div class="future-card"
           data-title="{{ product.title | downcase }}"
           data-price="{{ product.price }}"
           data-handle="{{ product.handle }}">

        <div class="future-img">
          <img src="{{ product.featured_image | image_url: width: 800 }}">
          <div class="orb">+</div>
        </div>

        <div class="future-info">
          <h3>{{ product.title }}</h3>
          <p>{{ product.price | money }}</p>
        </div>

      </div>

      {% endif %}
    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "Custom Grid",
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ],
  "max_blocks": 6
}
{% endschema %}

<style>
/* BACKGROUND */
.future-shop{
  display:flex;
  gap:20px;
  padding:40px;
  background:radial-gradient(circle at top,#0b0f1a,#05070d);
  color:#fff;
  font-family:Arial;
}

/* FILTER */
.future-filter{
  width:240px;
  position:sticky;
  top:20px;
  background:rgba(255,255,255,0.05);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,0.1);
  padding:15px;
  border-radius:15px;
}

/* GRID */
.future-grid{
  flex:1;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:25px;
}

/* CARD */
.future-card{
  background:rgba(255,255,255,0.06);
  backdrop-filter:blur(18px);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:18px;
  overflow:hidden;
  transition:0.4s;
  position:relative;
}

.future-card:hover{
  transform:translateY(-10px) scale(1.02);
  box-shadow:0 20px 50px rgba(0,255,255,0.15);
}

/* IMAGE */
.future-img{
  position:relative;
  aspect-ratio:1/1;
  overflow:hidden;
}

.future-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:1s;
}

.future-card:hover img{
  transform:scale(1.1) rotate(1deg);
}

/* ORB BUTTON */
.orb{
  position:absolute;
  top:10px;
  right:10px;
  width:40px;
  height:40px;
  border-radius:50%;
  background:linear-gradient(45deg,#00f5ff,#0066ff);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:22px;
  cursor:pointer;
  box-shadow:0 0 20px #00f5ff;
}

/* INFO */
.future-info{
  padding:15px;
}

/* RESPONSIVE */
@media(max-width:1024px){
  .future-grid{grid-template-columns:repeat(3,1fr);}
}

@media(max-width:768px){
  .future-shop{flex-direction:column;}
  .future-grid{grid-template-columns:repeat(2,1fr);}
}

@media(max-width:480px){
  .future-grid{grid-template-columns:1fr;}
}
</style>

<script>
const cards = document.querySelectorAll(".future-card");

/* SEARCH */
document.getElementById("search").addEventListener("input",(e)=>{
  let val = e.target.value.toLowerCase();

  cards.forEach(c=>{
    c.style.display = c.dataset.title.includes(val) ? "block":"none";
  });
});

/* PRICE */
document.getElementById("price").addEventListener("input",(e)=>{
  let max = e.target.value;

  cards.forEach(c=>{
    c.style.display = parseInt(c.dataset.price) <= max ? "block":"none";
  });
});

/* CLICK EFFECT */
document.querySelectorAll(".orb").forEach(orb=>{
  orb.addEventListener("click",(e)=>{
    e.stopPropagation();

    const card = orb.closest(".future-card");

    card.style.boxShadow = "0 0 40px #00f5ff";
    setTimeout(()=>card.style.boxShadow="",500);
  });
});

</script>