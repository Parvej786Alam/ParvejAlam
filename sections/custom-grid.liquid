{% liquid
  assign collection = section.settings.collection
  assign max_items = section.settings.product_count
  assign columns = section.settings.columns
%}

<section class="featured-collection section-{{ section.id }}">

  {% if section.settings.title != blank %}
    <div class="section-header">
      <h2>{{ section.settings.title }}</h2>

      {% if section.settings.show_view_all and collection != blank %}
        <a href="{{ collection.url }}" class="view-all">View all</a>
      {% endif %}
    </div>
  {% endif %}

  <div class="product-grid">

    {% for product in collection.products limit: max_items %}

        <div class="product-card">

          <a href="{{ product.url }}" class="image-wrapper">
            <img src="{{ product.featured_image | image_url: width: 800 }}">
          </a>
        
          <!-- + BUTTON -->
          <button class="qv-btn" data-id="{{ product.id }}">+</button>
        
          <!-- PRODUCT JSON -->
          <script type="application/json" id="product-data-{{ product.id }}">
            {{ product | json }}
          </script>
        
        </div>

    {% endfor %}

  </div>

</section>

<div id="qv-modal" class="qv-modal">
  <div class="qv-box">

    <span class="qv-close">×</span>

    <div class="qv-grid">

      <div class="qv-left">
        <img id="qv-img">
      </div>

      <div class="qv-right">

        <h2 id="qv-title"></h2>
        <p id="qv-price"></p>
        <p id="qv-desc"></p>

        <div class="qv-option">
          <label>Color</label>
          <div id="qv-colors"></div>
        </div>

        <div class="qv-option">
          <label>Size</label>
          <select id="qv-size"></select>
        </div>

        <button id="qv-add">ADD TO CART</button>

      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Product count"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 16,
      "label": "Gap"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All"
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}

<style>
    .featured-collection {
      padding: 40px;
    }
    
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
    
    .section-header h2 {
      font-size: 22px;
      font-weight: 500;
    }
    
    .view-all {
      font-size: 14px;
      text-decoration: underline;
    }
    
    .featured-collection {
      width: 100%;
      max-width: 100%;
    }
    
    .product-grid {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }
    
    /* Shopify style responsive */
    @media(max-width: 990px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media(max-width: 600px) {
      .product-grid {
        grid-template-columns: repeat(1, 1fr);
      }
    }
    
    .product-card {
      text-align: left;
    }
    
    .image-wrapper {
      display: block;
      aspect-ratio: 1/1.2;
      overflow: hidden;
    }
    
    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: 0.4s;
    }
    
    .product-card:hover img {
      transform: scale(1.05);
    }
    
    .product-info h3 {
      font-size: 14px;
      margin-top: 10px;
    }
    
    .product-info p {
      font-size: 13px;
      opacity: 0.7;
    }
    
    .product-info {
       display: none;
    }
    
    .qv-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      justify-content: center;
      align-items: center;
      z-index: 9999;
    }
    
    .qv-box {
      background: #fff;
      width: 850px;
      padding: 30px;
      position: relative;
    }
    
    .qv-close {
      position: absolute;
      top: 10px;
      right: 15px;
      font-size: 22px;
      cursor: pointer;
    }
    
    .qv-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
    
    .qv-left img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .qv-right h2 {
      font-size: 18px;
      margin-bottom: 10px;
    }
    
    .qv-option {
      margin-top: 15px;
    }
    
    #qv-colors button {
      border: 1px solid #000;
      background: #fff;
      padding: 6px 12px;
      margin-right: 6px;
      cursor: pointer;
    }
    
    #qv-add {
      margin-top: 20px;
      width: 100%;
      background: black;
      color: white;
      padding: 12px;
      border: none;
      cursor: pointer;
    }
    
    .qv-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 1px solid #000;
      background: #fff;
      cursor: pointer;
      opacity: 0;
      transition: 0.3s;
    }
    
    .product-card {
      position: relative;
    }
    
    .product-card:hover .qv-btn {
      opacity: 1;
    }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const modal = document.getElementById("qv-modal");

  if (!modal) return;

  // CLOSE MODAL
  const closeBtn = document.querySelector(".qv-close");
  if (closeBtn) {
    closeBtn.addEventListener("click", () => {
      modal.style.display = "none";
    });
  }

  // OPEN POPUP ON + BUTTON CLICK
  document.querySelectorAll(".qv-btn").forEach(btn => {

    btn.addEventListener("click", () => {

      const id = btn.dataset.id;

      const productEl = document.getElementById(`product-data-${id}`);
      if (!productEl) return;

      const product = JSON.parse(productEl.textContent);

      // OPEN MODAL
      modal.style.display = "flex";

      // BASIC DATA
      const titleEl = document.getElementById("qv-title");
      const priceEl = document.getElementById("qv-price");
      const imgEl = document.getElementById("qv-img");
      const descEl = document.getElementById("qv-desc");

      if (titleEl) titleEl.innerText = product.title;
      if (priceEl) priceEl.innerText = (product.price / 100).toFixed(2) + " ";
      if (imgEl) imgEl.src = product.images?.[0] || "";
      if (descEl) descEl.innerText = product.description || "";

      // VARIANTS SAFE HANDLING
      let colors = new Set();
      let sizes = new Set();

      product.variants.forEach(v => {
        if (v.option1) colors.add(v.option1);
        if (v.option2) sizes.add(v.option2);
      });

      const colorBox = document.getElementById("qv-colors");
      const sizeBox = document.getElementById("qv-size");

      if (colorBox) colorBox.innerHTML = "";
      if (sizeBox) sizeBox.innerHTML = "";

      let selectedColor = product.variants[0]?.option1 || "";
      let selectedSize = product.variants[0]?.option2 || "";

      // COLOR BUTTONS
      colors.forEach(color => {
        const btn = document.createElement("button");
        btn.innerText = color;

        btn.addEventListener("click", () => {
          selectedColor = color;

          // active class (optional UI)
          colorBox.querySelectorAll("button").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
        });

        colorBox.appendChild(btn);
      });

      // SIZE OPTIONS
      sizes.forEach(size => {
        const opt = document.createElement("option");
        opt.value = size;
        opt.text = size;
        sizeBox.appendChild(opt);
      });

      sizeBox.value = selectedSize;

      sizeBox.onchange = (e) => {
        selectedSize = e.target.value;
      };

      // ADD TO CART
      const addBtn = document.getElementById("qv-add");

      if (addBtn) {
        addBtn.onclick = () => {

          const variant = product.variants.find(v =>
            v.option1 === selectedColor &&
            v.option2 === selectedSize
          );

          if (!variant) {
            alert("Variant not found");
            return;
          }

          fetch("/cart/add.js", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              id: variant.id,
              quantity: 1
            })
          })
          .then(res => res.json())
          .then(() => {
            alert("Added to cart");
          });

        };
      }

    });

  });

});
</script>

