<section class="custom-banner" style="background-image: url({{ section.settings.background_image | image_url }})">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_link }}" class="btn">
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]

}
{% endschema %}

<style>
.custom-banner {
  position: relative;
  width: 100%;
  height: 80vh;
  min-height: 500px;
  display: flex;
  align-items: flex-end; /* bottom */
  justify-content: flex-start; /* left */
  padding: 60px 80px;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: #fff;
}

.custom-banner .container {
  position: relative;
  z-index: 2;
  max-width: 600px;
}

/* Heading */
.custom-banner h1 {
   font-size: 70px;
   font-weight: 500;
   color: #000;
   margin-bottom: 15px;
   font-family: 'Jost';
   line-height: 100%;
   letter-spacing: 0;
}

/* Subheading */
.custom-banner p {
  font-size: 18px;
  margin-bottom: 25px;
  opacity: 0.9;
}

/* Button */
.custom-banner .btn {
  display: inline-block;
  padding: 14px 28px;
  background-color: #ffffff;
  color: #000;
  font-size: 16px;
  font-weight: 600;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

/* Button hover animation */
.custom-banner .btn:hover {
  background-color: #000;
  color: #fff;
  transform: translateY(-3px);
}

/* subtle shine effect */
.custom-banner .btn::after {
  content: "";
  position: absolute;
  top: 0;
  left: -75%;
  width: 50%;
  height: 100%;
  background: rgba(255,255,255,0.4);
  transform: skewX(-25deg);
  transition: 0.5s;
}

.custom-banner .btn:hover::after {
  left: 130%;
}

/* ========================= */
/* 📱 Responsive */
/* ========================= */

@media (max-width: 1024px) {
  .custom-banner {
    padding: 50px 40px;
    height: 70vh;
  }

  .custom-banner h1 {
    font-size: 38px;
  }
}

@media (max-width: 768px) {
  .custom-banner {
    padding: 30px 20px;
    height: 60vh;
  }

  .custom-banner h1 {
    font-size: 28px;
  }

  .custom-banner p {
    font-size: 16px;
  }

  .custom-banner .btn {
    padding: 12px 22px;
    font-size: 14px;
  }
}

@media (max-width: 480px) {
  .custom-banner {
    height: 55vh;
    padding: 20px 15px;
  }

  .custom-banner h1 {
    font-size: 24px;
  }
}
</style>