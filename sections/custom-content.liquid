<section style="background: {{ section.settings.bg_color }}; padding: 10px 0;">
  <div style="max-width: 900px; margin: auto; text-align: center;">

    {% if section.settings.content != blank %}
      <div style="color: {{ section.settings.text_color }}; font-size: 16px; line-height: 1.6;">
        {{ section.settings.content }}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Simple Content Section",
  "settings": [
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Write your content here..."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Simple Content Section"
    }
  ]
}
{% endschema %}