<section style="background: {{ section.settings.bg_color }}; padding: 60px 20px;">
  <div style="max-width: 900px; margin: auto; text-align: center;">

    {% if section.settings.title != blank %}
      <h2 style="color: {{ section.settings.text_color }}; font-size: 32px; margin-bottom: 20px;">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {% if section.settings.content != blank %}
      <div style="color: {{ section.settings.text_color }}; font-size: 16px; line-height: 1.6;">
        {{ section.settings.content }}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Simple Content Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Your Heading Here"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Write your content here..."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Simple Content Section"
    }
  ]
}
{% endschema %}