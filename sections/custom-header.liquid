<header class="custom-header" id="customHeader">
  <div class="header-wrapper">

    <!-- LEFT: LOGO -->
    <div class="header-left">
      <a href="/">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url }}" class="header-logo" alt="logo">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- CENTER: TEXT + MENU -->
    <div class="header-center">

      {% if section.settings.center_text != blank %}
        <p class="center-text">{{ section.settings.center_text }}</p>
      {% endif %}

      {% if section.settings.menu != blank %}
        <nav class="desktop-menu">
          <ul>
            {% for link in section.settings.menu.links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

    </div>

    <!-- RIGHT: BUTTON -->
    <div class="header-right">
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="header-btn">
          <span>{{ section.settings.button_text }}</span>

          {% if section.settings.arrow_icon != blank %}
            <img src="{{ section.settings.arrow_icon | image_url }}" class="btn-arrow" alt="arrow">
          {% endif %}
        </a>
      {% endif %}
    </div>

    <!-- MOBILE TOGGLE -->
    <div class="mobile-toggle" id="mobileToggle">
      ☰
    </div>

  </div>
</header>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-header">
    <span>Menu</span>
    <button id="closeMenu">✕</button>
  </div>

  <ul>
    {% for link in section.settings.menu.links %}
      <li>
        <a href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "center_text",
      "label": "Center Text",
      "default": "Welcome to our store"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "arrow_icon",
      "label": "Arrow Icon"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}

<style>
/* HEADER */
.custom-header {
  position: sticky;
  top: 0;
  z-index: 999;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(10px);
  padding: 15px 40px;
}

/* LAYOUT */
.header-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

/* LOGO FIXED */
.header-logo {
  max-height: 40px;
  width: auto;
}

/* CENTER */
.header-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
}

/* CENTER TEXT */
.center-text {
  font-size: 13px;
  margin-bottom: 6px;
  font-weight: 500;
}

/* MENU */
.desktop-menu ul {
  display: flex;
  gap: 25px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.desktop-menu a {
  text-decoration: none;
  color: #000;
  font-size: 14px;
}

/* BUTTON */
.header-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  background: #000;
  color: #fff;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

/* hover animation */
.header-btn::before {
  content: "";
  position: absolute;
  width: 0%;
  height: 100%;
  background: #FFF544;
  left: 0;
  top: 0;
  transition: 0.4s;
  z-index: -1;
}

.header-btn:hover::before {
  width: 100%;
}

.header-btn:hover {
  color: #000;
}

/* ARROW */
.btn-arrow {
  width: 16px;
  transition: 0.3s;
}

.header-btn:hover .btn-arrow {
  transform: translateX(5px);
}

/* MOBILE TOGGLE */
.mobile-toggle {
  display: none;
  font-size: 24px;
  cursor: pointer;
}

/* MOBILE MENU */
.mobile-menu {
  position: fixed;
  top: 0;
  right: -100%;
  width: 80%;
  height: 100%;
  background: #fff;
  padding: 20px;
  transition: 0.4s;
  z-index: 9999;
}

.mobile-menu.active {
  right: 0;
}

.mobile-menu-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

.mobile-menu ul {
  list-style: none;
  padding: 0;
}

.mobile-menu li {
  margin: 20px 0;
}

.mobile-menu a {
  text-decoration: none;
  font-size: 18px;
  color: #000;
}

/* RESPONSIVE */
@media (max-width: 768px) {

  .header-center {
    display: none;
  }

  .header-right {
    display: none;
  }

  .mobile-toggle {
    display: block;
  }

  .header-logo {
    max-height: 32px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const openBtn = document.getElementById("mobileToggle");
  const closeBtn = document.getElementById("closeMenu");
  const menu = document.getElementById("mobileMenu");

  openBtn.addEventListener("click", () => {
    menu.classList.add("active");
  });

  closeBtn.addEventListener("click", () => {
    menu.classList.remove("active");
  });
});
</script>