<header class="custom-header">
  <div class="header-wrapper">

    <!-- MOBILE TOGGLE -->
    <div class="mobile-toggle" id="mobileToggle">☰</div>

    <!-- LOGO -->
    <div class="header-left">
      <a href="/">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url }}" class="header-logo" alt="logo">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- CENTER CONTENT -->
    <div class="header-center">
      {% if section.settings.center_text != blank %}
        <p class="center-text">{{ section.settings.center_text }}</p>
      {% endif %}
    </div>

    <!-- BUTTON -->
    <div class="header-right">
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="header-btn">
          <span>{{ section.settings.button_text }}</span>
          {% if section.settings.arrow_icon != blank %}
            <img src="{{ section.settings.arrow_icon | image_url }}" class="btn-arrow" alt="arrow">
          {% endif %}
        </a>
      {% endif %}
    </div>

  </div>
</header>

<!-- MOBILE DRAWER -->
<div class="mobile-menu" id="mobileMenu">

  <div class="mobile-menu-header">
    <button id="closeMenu">✕</button>
    <span>Menu</span>
  </div>

  {% if section.settings.center_text != blank %}
    <p class="mobile-center-text">{{ section.settings.center_text }}</p>
  {% endif %}

   <div class="mobile-menu-content">
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="header-btn mobile-btn">
        <span>{{ section.settings.button_text }}</span>
        {% if section.settings.arrow_icon != blank %}
          <img src="{{ section.settings.arrow_icon | image_url }}" class="btn-arrow" alt="arrow">
        {% endif %}
      </a>
    {% endif %}
  </div>

</div>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "center_text",
      "label": "Center Text",
      "default": "Welcome to our store"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "arrow_icon",
      "label": "Arrow Icon"
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}

<style>
.custom-header {
  position: sticky;
  top: 0;
  z-index: 999;
  background: #F5F5F5;
  padding: 15px 40px;
}

.header-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.header-logo {
  max-height: 40px;
}

/* CENTER DESKTOP */
.header-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
}

.center-text {
  font-size: 14px;
}

/* BUTTON */
.header-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  background: #FFF544;
  color: #000;
  text-decoration: none;
  position: relative;
  overflow: hidden;
}

.header-btn::before {
  content: "";
  position: absolute;
  width: 0%;
  height: 100%;
  background: #000;
  transition: 0.4s;
  z-index: -1;
}

.header-btn:hover::before {
  width: 100%;
}

.header-btn:hover {
  color: #fff;
}

.btn-arrow {
  width: 16px;
  filter: invert(1);
  transition: 0.3s;
}

.header-btn:hover .btn-arrow {
  transform: translateX(5px);
  filter: invert(0);
}

/* MOBILE */
.mobile-toggle {
  display: none;
  font-size: 24px;
  cursor: pointer;
}

/* DRAWER */
.mobile-menu {
  position: fixed;
  top: 0;
  left: -100%;
  width: 80%;
  height: 100%;
  background: #fff;
  padding: 20px;
  transition: 0.4s;
  z-index: 9999;
}

.mobile-menu.active {
  left: 0;
}

.mobile-menu-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40px;
}

.mobile-center-text {
  text-align: center;
  margin-bottom: 20px;
}

/* MOBILE BUTTON */
.mobile-menu-content .mobile-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 14px;
  background: #FFF544;
  color: #000;
  text-decoration: none;
  position: relative;
  overflow: hidden;
}

.mobile-menu-content .mobile-btn::before {
  content: "";
  position: absolute;
  width: 0%;
  height: 100%;
  background: #000;
  transition: 0.4s;
  z-index: -1;
}

.mobile-menu-content .mobile-btn:hover::before {
  width: 100%;
}

.mobile-menu-content .mobile-btn:hover {
  color: #fff;
}

/* RESPONSIVE */
@media (max-width: 768px) {

  .custom-header {
    padding: 12px 15px;
  }

  .mobile-toggle {
    display: block;
  }

  .header-left {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .header-right {
    display: none;
  }

  .header-center {
    display: none;
  }

  .header-logo {
    max-height: 32px;
  }

  .mobile-menu-content .mobile-btn {
        position: absolute;
        top: 120px;
        left: 50%;
        transform: translateX(-50%);
        display: inline-flex;
        align-items: center;
        gap: 29px;
        padding: 13px 20px 13px 20px;
        background: #FFF544;
        color: #000;
        font-size: 16px;
        overflow: hidden;
        width: 70%;
        height: fit-content;
    }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const openBtn = document.getElementById("mobileToggle");
  const closeBtn = document.getElementById("closeMenu");
  const menu = document.getElementById("mobileMenu");

  openBtn.addEventListener("click", () => {
    menu.classList.add("active");
  });

  closeBtn.addEventListener("click", () => {
    menu.classList.remove("active");
  });
});
</script>